# Plantilla de variables de entorno — EstacionaAPI
# 1. Copia este archivo y renómbralo a ".env"
# 2. Rellena los valores con tus credenciales locales
# 3. NUNCA subas el ".env" al repositorio (ya está en .gitignore)

# --- Base de datos PostgreSQL ---
# Usuario con permisos sobre la base de datos "estaciona_db"
DB_USER=postgres

# Contraseña del usuario de PostgreSQL
DB_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# --- Seguridad JWT ---
# Clave secreta para firmar los tokens JWT (algoritmo HS256)
# REQUISITO: mínimo 32 caracteres. No cambiar en producción
# Genera una nueva clave con: openssl rand -base64 32
JWT_SECRET=GENERA_UNA_CLAVE_SEGURA_DE_AL_MENOS_32_CARACTERES
